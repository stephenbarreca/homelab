{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Flux Operator group",
      groupName: "Flux Operator",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "/flux-operator/",
        "/flux-instance/",
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      }
    }
  ]
}